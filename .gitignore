# macOS
.DS_Store
.AppleDouble
.LSOverride

# Build outputs (regenerated by build.sh / package.sh)
build/
dist/
*.iconset/

# Xcode (in case the Swift files are opened in Xcode for editing)
xcuserdata/
*.xcuserstate
*.xcodeproj/project.xcworkspace/
DerivedData/

# Swift Package Manager (if it gets adopted later)
.build/
.swiftpm/
Packages/
Package.resolved

# Editor / temp
*.swp
*.swo
*.tmp
*~

# Logs (local development)
*.log
